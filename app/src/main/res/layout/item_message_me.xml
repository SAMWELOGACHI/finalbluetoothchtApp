<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="8dp"
    android:paddingVertical="4dp">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cvMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="#005C4B"
        app:cardCornerRadius="16dp"
        app:cardElevation="1dp"
        app:strokeWidth="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.App.MessageSent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:maxWidth="260dp">

            <!-- Replied Quote View -->
            <LinearLayout
                android:id="@+id/layoutQuote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:visibility="gone"
                android:background="#15FFFFFF"
                android:layout_marginHorizontal="6dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="2dp"
                android:paddingEnd="6dp">

                <View
                    android:id="@+id/quoteIndicator"
                    android:layout_width="4dp"
                    android:layout_height="match_parent"
                    android:background="#00A884" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="6dp"
                    android:layout_marginVertical="4dp">

                    <TextView
                        android:id="@+id/tvQuoteSender"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Alice"
                        android:textColor="#34D399"
                        android:textSize="11sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvQuoteText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Quoted text"
                        android:textColor="#D1D5DB"
                        android:textSize="11sp"
                        android:maxLines="2"
                        android:ellipsize="end" />
                </LinearLayout>
            </LinearLayout>

            <ImageView
                android:id="@+id/ivImage"
                android:layout_width="240dp"
                android:layout_height="wrap_content"
                android:maxHeight="240dp"
                android:adjustViewBounds="true"
                android:scaleType="centerCrop"
                android:visibility="gone" />

            <!-- Audio Voice Note Player Row -->
            <LinearLayout
                android:id="@+id/layoutAudio"
                android:layout_width="240dp"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="8dp"
                android:gravity="center_vertical"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/btnPlayPause"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_play"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="@color/white"
                    android:contentDescription="Play Audio" />

                <SeekBar
                    android:id="@+id/sbAudioProgress"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="100" />

                <TextView
                    android:id="@+id/tvAudioDuration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0:00"
                    android:textColor="#E5E7EB"
                    android:textSize="11sp"
                    android:layout_marginEnd="4dp"/>

            </LinearLayout>

            <TextView
                android:id="@+id/tvMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="12dp"
                android:paddingTop="6dp"
                android:paddingBottom="2dp"
                android:text="Message content"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:maxWidth="260dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_gravity="end"
                android:paddingHorizontal="8dp"
                android:paddingBottom="4dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvTimestamp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="12:00 PM"
                    android:textColor="#B0FFFFFF"
                    android:textSize="9sp" />

                <ImageView
                    android:id="@+id/ivStatus"
                    android:layout_width="13dp"
                    android:layout_height="13dp"
                    android:layout_marginStart="4dp"
                    android:src="@drawable/ic_check"
                    app:tint="#B0FFFFFF" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Reaction Badge overlaying bottom right corner of CardView -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cvReaction"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:cardCornerRadius="10dp"
        app:cardBackgroundColor="#202C33"
        app:cardElevation="2dp"
        app:strokeWidth="1dp"
        app:strokeColor="#2E3B4E"
        app:layout_constraintBottom_toBottomOf="@id/cvMessage"
        app:layout_constraintEnd_toEndOf="@id/cvMessage"
        android:layout_marginBottom="-8dp"
        android:layout_marginEnd="8dp">

        <TextView
            android:id="@+id/tvReaction"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="❤️"
            android:textSize="11sp"
            android:paddingHorizontal="4dp"
            android:paddingVertical="1dp"
            android:textColor="@color/text_primary" />
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>